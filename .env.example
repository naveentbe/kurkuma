# Google Sheets Apps Script web app URL (must end with /exec, deployed as "Anyone")
# Deploy from the spreadsheet: Extensions > Apps Script > Deploy > New deployment > Web app
GOOGLE_SHEETS_WEB_APP_URL=

# Zenchef booking widget (floating button bottom-right when HIDE_BUTTON=false)
NEXT_PUBLIC_ZENCHEF_RESTAURANT_ID=357246
NEXT_PUBLIC_ZENCHEF_PRIMARY_COLOR=eaaa48
NEXT_PUBLIC_ZENCHEF_LANG=en
NEXT_PUBLIC_ZENCHEF_HIDE_BUTTON=false
NEXT_PUBLIC_ZENCHEF_POSITION=right
# If the widget is not yet enabled in Zenchef dashboard, preview with: http://localhost:3000/?isPreview=true
